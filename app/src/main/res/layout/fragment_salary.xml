<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💼 Meu Salário"
            android:textColor="#1E293B"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure os dias e valores do seu salário"
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- Card principal -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dias de recebimento"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Container dinâmico de entradas -->
                <LinearLayout
                    android:id="@+id/containerSalaryEntries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Botão adicionar outro dia -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddSalaryEntry"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="+ Adicionar outro dia de recebimento"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#6C63FF"
                    android:textColor="#6C63FF" />

                <!-- Botão salvar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveSalary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Salvar configuração"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#6C63FF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card info -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EEF2FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Como funciona"
                    android:textColor="#4338CA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSalaryStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Configure acima seu salário e os dias de recebimento. A cada mês, ao abrir o app após esses dias, os valores serão lançados automaticamente como receita."
                    android:textColor="#4338CA"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>